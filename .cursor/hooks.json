{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "python3 \"$CURSOR_PROJECT_DIR/.automations/give-student-credit.py\" --tool=cursor --event=afterFileEdit || python \"$CURSOR_PROJECT_DIR/.automations/give-student-credit.py\" --tool=cursor --event=afterFileEdit"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "python3 \"$CURSOR_PROJECT_DIR/.automations/give-student-credit.py\" --tool=cursor --event=afterTabFileEdit || python \"$CURSOR_PROJECT_DIR/.automations/give-student-credit.py\" --tool=cursor --event=afterTabFileEdit"
      }
    ]
  }
}
